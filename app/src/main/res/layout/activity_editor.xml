<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context="com.example.editor.EditorActivity">

    <!-- Top Action Bar (Header) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0C0C0E"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Outer Flex Container for Brand Badge and Title Info -->
        <LinearLayout
            android:id="@+id/header_brand_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- AI Brand Badge -->
            <FrameLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_badge_ai"
                android:layout_marginEnd="10dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="AI"
                    android:textColor="@color/black"
                    android:textSize="10sp"
                    android:textStyle="bold|italic" />
            </FrameLayout>

            <!-- Titles and specs -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_project_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UNTITLED PROJECT"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tv_project_specs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1080p • 24fps • 00:14:22"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_undo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_glass_button"
            android:contentDescription="Undo"
            android:padding="6dp"
            android:src="@drawable/ic_undo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_redo"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_redo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_glass_button"
            android:contentDescription="Redo"
            android:padding="6dp"
            android:src="@drawable/ic_redo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_save"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_save"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_glass_button"
            android:contentDescription="Save Project"
            android:padding="6dp"
            android:src="@drawable/ic_save"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_ai_hub"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ai_hub"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginEnd="16dp"
            android:text="AI Hub"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_fx"
            app:iconSize="16dp"
            app:iconTint="@color/accent_cyan"
            app:backgroundTint="@color/accent_cyan_transparent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_export"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Export"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_export"
            app:iconSize="16dp"
            app:iconTint="@color/black"
            app:backgroundTint="@color/accent_cyan"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Side Toolbar Panel (Left) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/sidebar_panel"
        android:layout_width="66dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/bg_dark"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bar">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="8dp"
                android:gravity="center_horizontal">

                <!-- Import Tool -->
                <ImageButton
                    android:id="@+id/tool_import"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Import"
                    android:src="@drawable/ic_audio"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Split Tool -->
                <ImageButton
                    android:id="@+id/tool_split"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Split"
                    android:src="@drawable/ic_split"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Trim Tool -->
                <ImageButton
                    android:id="@+id/tool_trim"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Trim"
                    android:src="@drawable/ic_trim"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Speed Tool -->
                <ImageButton
                    android:id="@+id/tool_speed"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Speed"
                    android:src="@drawable/ic_speed"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- FX Effects Tool -->
                <ImageButton
                    android:id="@+id/tool_fx"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="FX Effects"
                    android:src="@drawable/ic_fx"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Color Grading / Filter Tool -->
                <ImageButton
                    android:id="@+id/tool_filter"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Filters"
                    android:src="@drawable/ic_filter"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Colors Custom Slider -->
                <ImageButton
                    android:id="@+id/tool_color_grading"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Color Grading"
                    android:src="@drawable/ic_chromakey"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Crop Tool -->
                <ImageButton
                    android:id="@+id/tool_crop"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Crop"
                    android:src="@drawable/ic_crop"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Cutout Segmentation Tool -->
                <ImageButton
                    android:id="@+id/tool_cutout"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Cutout"
                    android:src="@drawable/ic_cutout"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Text Overlay Tool -->
                <ImageButton
                    android:id="@+id/tool_text"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Add Text"
                    android:src="@drawable/ic_text"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Sticker Overlay Tool -->
                <ImageButton
                    android:id="@+id/tool_sticker"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Add Sticker"
                    android:src="@drawable/ic_sticker"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Voiceover Recorder Tool -->
                <ImageButton
                    android:id="@+id/tool_voice"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Voiceover"
                    android:src="@drawable/ic_voice"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Keyframe Mode Tool -->
                <ImageButton
                    android:id="@+id/tool_keyframe"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Keyframe Animator"
                    android:src="@drawable/ic_keyframe"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Auto Subtitles Tool -->
                <ImageButton
                    android:id="@+id/tool_subtitles"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="AI Subtitles"
                    android:src="@drawable/ic_transition"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- AI Generation Tool -->
                <ImageButton
                    android:id="@+id/tool_ai_generate"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="AI Generator"
                    android:src="@drawable/ic_ai_generated"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <!-- Library Storage Tool -->
                <ImageButton
                    android:id="@+id/tool_library"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginVertical="4dp"
                    android:background="@drawable/bg_glass_button"
                    android:contentDescription="Library"
                    android:src="@drawable/ic_save"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Main Viewport workspace (Right side) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/viewport_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_timeline_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar_panel"
        app:layout_constraintTop_toBottomOf="@id/header_bar">

        <!-- Outer Glass Preview Window (60% upper part default ratio) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/preview_card"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#121215"
            app:layout_constraintBottom_toTopOf="@id/player_controls"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Video Display TextureView -->
                <TextureView
                    android:id="@+id/video_texture_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center" />

                <!-- Overlay Watermark -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:text="AI VIDEO EDITOR PRO"
                    android:textColor="#33FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <!-- Text Overlay Layer (Dynamic Drag text placement) -->
                <TextView
                    android:id="@+id/overlay_preview_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="#60000000"
                    android:elevation="6dp"
                    android:padding="8dp"
                    android:text="Double-tap text to edit"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Sticker Overlay Layer -->
                <ImageView
                    android:id="@+id/overlay_preview_sticker"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:elevation="6dp"
                    android:src="@drawable/ic_sticker"
                    android:visibility="gone" />

                <!-- Active Mask Render overlay simulation -->
                <View
                    android:id="@+id/mask_overlay_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#3300E5FF"
                    android:visibility="gone" />

                <!-- LUT Filter/Shaders simulation overlay -->
                <View
                    android:id="@+id/effect_overlay_shader"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent" />

                <!-- Audio Subtitle dynamic caption layout inside video -->
                <TextView
                    android:id="@+id/tv_active_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_subtitle_capsule"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Player Seekbar & Play/Pause controls stacked below preview -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/player_controls"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/btn_play_pause"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_glass_button"
                android:contentDescription="Play/Pause"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/accent_cyan"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_current_timecode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="00:00.0"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="monospace"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btn_play_pause"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_divider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="/"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_current_timecode"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_total_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="00:10.0"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_divider"
                app:layout_constraintTop_toTopOf="parent" />

            <SeekBar
                android:id="@+id/playback_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:max="1000"
                android:progress="0"
                android:progressTint="@color/accent_cyan"
                android:thumbTint="@color/accent_cyan"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_total_duration"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Timeline Context Header Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/timeline_context_bar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:background="@color/surface_dark"
        app:layout_constraintBottom_toTopOf="@id/bottom_timeline_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar_panel"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/tv_active_track_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timeline Grid Layout"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/action_delete_clip"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_glass_button"
            android:contentDescription="Delete Clip"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_delete"
            android:visibility="gone"
            app:tint="@color/red_accent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/action_duplicate_clip"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/action_duplicate_clip"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_glass_button"
            android:contentDescription="Duplicate Clip"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_add"
            android:visibility="gone"
            app:tint="@color/accent_cyan"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Synchronized Multi-Track Timeline (Bottom Area) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_timeline_panel"
        android:layout_width="0dp"
        android:layout_height="204dp"
        android:background="@color/bg_dark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar_panel">

        <!-- Edge to edge Playhead cursor static center view overlay -->
        <View
            android:id="@+id/playhead_vertical_indicator"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="@color/accent_cyan"
            android:elevation="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_timeline_tracks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:clipToPadding="false" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

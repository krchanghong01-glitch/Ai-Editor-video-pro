<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface_dark"
    app:behavior_peekHeight="320dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SELECT LUT RETROME FILTERS (15 PRESETS)"
        android:textColor="@color/accent_cyan"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="180dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filter_chip_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_vintage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎥 Vintage Nostalgia (1970)"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_drama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎭 High Contrast Drama"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cyberpunk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌆 Cyberpunk Neon #00E5FF"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_noir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕶️ Classic Noir Monochrome"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_softglow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Soft Dreamy Glow"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_coldblue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❄️ Arctic Blue Chill"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_golden"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌅 Deep Golden Sunset"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_forest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌲 Emerald Green Forest"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_retro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📻 Retro CRT Monitor"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cinematic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎬 Hollywood Anamorphic"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_sepia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📜 Ancient Sepia Codex"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_vaporwave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌸 Vaporwave Pastel Dream"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_neonoir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Hot Pink Neo-Noir"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_monochrome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🪙 Silver Metalloid"
                android:textColor="@color/white" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_sunset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌋 Obsidian Volcanic"
                android:textColor="@color/white" />

        </com.google.android.material.chip.ChipGroup>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

         <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_filter"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset Filters"
            android:textColor="@color/red_accent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_filter_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Apply LUT"
            android:textColor="@color/black"
            app:backgroundTint="@color/accent_cyan" />

    </LinearLayout>

</LinearLayout>

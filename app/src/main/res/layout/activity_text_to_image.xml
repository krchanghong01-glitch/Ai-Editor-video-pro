<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/app_toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface_dark"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_glass_button"
            android:contentDescription="Go Back"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/accent_cyan"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="TEXT TO IMAGE ENGINE"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Entry Panel -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Model Selection Row -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Generative Model"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/surface_dark">

                <Spinner
                    android:id="@+id/spinner_models"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:paddingHorizontal="12dp"
                    android:theme="@android:style/Theme.DeviceDefault.Dialog" />
            </androidx.cardview.widget.CardView>

            <!-- Text Prompt Input -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Generative Text Prompt"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_prompt"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_glass_panel"
                android:gravity="top|start"
                android:hint="Describe the masterpiece you want to render (e.g. cinematic, 8k, detailed, photorealistic particle storm...)"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:padding="12dp"
                android:inputType="textMultiLine" />

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_generate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Render Aesthetic Image"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/accent_cyan"
                app:cornerRadius="26dp" />

            <!-- Render Status Progress Overlay -->
            <ProgressBar
                android:id="@+id/pb_rendering"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/accent_cyan"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_render_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Generating with Stable Diffusion XL..."
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Aesthetic Generated Preview Frame -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card">

                    <ImageView
                        android:id="@+id/iv_generated_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_ai_generated" />

                    <!-- Watermark indicating prompt name -->
                    <TextView
                        android:id="@+id/tv_prompt_overlay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#99000000"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:padding="8dp"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="italic" />

                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hook to add back to project -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_to_project"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Add to Timeline Track (V2)"
                android:textColor="@color/accent_cyan"
                android:visibility="gone"
                app:backgroundTint="@color/accent_cyan_transparent"
                app:strokeColor="@color/accent_cyan"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface_dark"
    app:behavior_peekHeight="300dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="APPLY HARDWARE GRAPHIC EFFECTS (FX)"
        android:textColor="@color/accent_cyan"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Horizontal scroll representation of 7 primary FX keys -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Glitch -->
            <LinearLayout
                android:id="@+id/btn_fx_glitch"
                android:layout_width="86dp"
                android:layout_height="80dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📺" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Glitch" android:textColor="@color/white" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- RGB Split -->
            <LinearLayout
                android:id="@+id/btn_fx_rgb"
                android:layout_width="86dp"
                android:layout_height="80dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💈" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RGB Split" android:textColor="@color/white" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Pixelate -->
            <LinearLayout
                android:id="@+id/btn_fx_pixel"
                android:layout_width="86dp"
                android:layout_height="80dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👾" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pixelate" android:textColor="@color/white" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Blur -->
            <LinearLayout
                android:id="@+id/btn_fx_blur"
                android:layout_width="86dp"
                android:layout_height="80dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌫️" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Blur" android:textColor="@color/white" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Sharpen -->
            <LinearLayout
                android:id="@+id/btn_fx_sharpen"
                android:layout_width="86dp"
                android:layout_height="80dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔪" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sharpen" android:textColor="@color/white" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Old Film -->
            <LinearLayout
                android:id="@+id/btn_fx_oldfilm"
                android:layout_width="86dp"
                android:layout_height="80dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📽️" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Old Film" android:textColor="@color/white" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Shake -->
            <LinearLayout
                android:id="@+id/btn_fx_shake"
                android:layout_width="86dp"
                android:layout_height="80dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📳" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shake" android:textColor="@color/white" android:textSize="11sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_fx"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="None"
            android:textColor="@color/red_accent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_fx_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Close Panel"
            android:textColor="@color/black"
            app:backgroundTint="@color/accent_cyan" />

    </LinearLayout>

</LinearLayout>

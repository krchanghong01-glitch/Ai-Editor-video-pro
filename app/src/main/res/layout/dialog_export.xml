<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface_dark">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="EXPORT SETTINGS &amp; COMPOSE"
        android:textColor="@color/accent_cyan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Resolution Choose -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Video Render Resolution"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_res_original"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="Original"
            android:textColor="@color/white"
            app:backgroundTint="@color/surface_dark_glass" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_res_1080p"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="1080p FHD"
            android:textColor="@color/accent_cyan"
            app:backgroundTint="@color/accent_cyan_transparent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_res_4k"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="4K UHD"
            android:textColor="@color/white"
            app:backgroundTint="@color/surface_dark_glass" />

    </LinearLayout>

    <!-- Encoding Format -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Encoding Format Codec"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_codec"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <RadioButton
            android:id="@+id/rb_h264"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H.264 (AVC Compatibility)"
            android:textColor="@color/white"
            android:layout_marginEnd="16dp"
            android:checked="true"/>
        <RadioButton
            android:id="@+id/rb_h265"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H.265 (HEVC Efficiency)"
            android:textColor="@color/white"/>
    </RadioGroup>

    <!-- Watermark options -->
    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switch_watermark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Include Cinematic Watermark (AI Video Editor Pro)"
        android:textColor="@color/white"
        android:layout_marginBottom="16dp"
        android:checked="true" />

    <!-- Action panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export_cancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export_begin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Compile &amp; Export"
            android:textColor="@color/black"
            app:backgroundTint="@color/accent_cyan" />

    </LinearLayout>

</LinearLayout>

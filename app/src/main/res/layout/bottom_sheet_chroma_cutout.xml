<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface_dark"
    app:behavior_peekHeight="380dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI SEGMENTATION, CHROMA KEY &amp; CUSTOM MASKS"
        android:textColor="@color/accent_cyan"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="14dp" />

    <!-- Toggle Buttons for features -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_ai_cutout"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="AI Cutout"
            android:textColor="@color/accent_cyan"
            app:backgroundTint="@color/accent_cyan_transparent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_chroma"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="Chroma Key"
            android:textColor="@color/white"
            app:backgroundTint="@color/surface_dark_glass" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_mask"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="2dp"
            android:text="Radial Mask"
            android:textColor="@color/white"
            app:backgroundTint="@color/surface_dark_glass" />

    </LinearLayout>

    <!-- Context area change panel -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Chroma Key layout -->
        <LinearLayout
            android:id="@+id/panel_chroma_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Color picker circle pick indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pick Color from Canvas: "
                    android:textColor="@color/white"
                    android:textSize="13sp"/>

                <View
                    android:id="@+id/chroma_picked_color_box"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_glass_card"
                    android:backgroundTint="#FF00FF00" />

                <ImageView
                    android:id="@+id/btn_eyedropper"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_chromakey"
                    android:background="@drawable/bg_glass_button"
                    android:padding="6dp"
                    app:tint="@color/accent_cyan"/>

            </LinearLayout>

            <TextView
                android:id="@+id/lbl_threshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Color Threshold: 15%"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_threshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.0"
                android:valueTo="100.0"
                android:value="15.0"
                app:thumbColor="@color/accent_cyan"
                app:trackColorActive="@color/accent_cyan" />

            <TextView
                android:id="@+id/lbl_feather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edge Feather: 2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_feather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.0"
                android:valueTo="20.0"
                android:value="2.0"
                app:thumbColor="@color/accent_cyan"
                app:trackColorActive="@color/accent_cyan" />

        </LinearLayout>

        <!-- AI Cutout layout -->
        <LinearLayout
            android:id="@+id/panel_ai_cutout_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Deep AI Segment Background Removal"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:text="Automated high-precision subject silhouette extraction. One tap to make video backgrounds transparent."
                android:textColor="@color/text_secondary"
                android:textSize="11sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_trigger_ai_cutout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Segment &amp; Remove Background"
                android:textColor="@color/black"
                app:backgroundTint="@color/accent_cyan" />

        </LinearLayout>

        <!-- Custom Radial Mask Layout -->
        <LinearLayout
            android:id="@+id/panel_mask_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Circle Radial Mask Overlay"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_invert_mask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="10dp"
                android:text="Invert Mask Area"
                android:textColor="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_trigger_mask"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Turn On Radial Overlay"
                android:textColor="@color/accent_cyan"
                app:backgroundTint="@color/accent_cyan_transparent"/>

        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_chroma_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Composite"
            android:textColor="@color/black"
            app:backgroundTint="@color/accent_cyan" />

    </LinearLayout>

</LinearLayout>
